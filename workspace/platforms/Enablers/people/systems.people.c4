    metadata {
      FAI 'APP00286'
      LifeCycle 'Retirar'
    }
    controlDeAsistencias -[supportsCapability]-> timeAndAttendance "Supports"
  }

  chatbotCorporativoBella = system 'Chatbot Corporativo BELLA'{
    #people
