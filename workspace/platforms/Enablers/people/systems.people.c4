    #people
    description 'Funcionalidad asociada a los convenios que el banco tiene con los funcionarios para los créditos que ellos toman con tasas preferentes, en donde se descuelgan o vinculan funcionarios.'
    administracionCartera -[supportsCapability]-> employeeMaster "Supports"
  }
  datamace = system 'Datamace' {
    #people
    description 'Sistema de Recursos Humanos para la administración del personal y para el pago de remuneraciones'
    datamace -[supportsCapability]-> employeeMaster "Supports"
    datamace -[supportsCapability]-> payrollCapability "Supports"

  }
  datapino = system 'Datapino' {
    #people
    description 'Gestión de novedades y pago de nomina a empleados|Aplicación para Gestión de Nómina de las empresas del Grupo y pago a empleados. Proveedor Digidata'
    datapino -[supportsCapability]-> employeeMaster "Supports"
    datapino -[supportsCapability]-> payrollCapability "Supports"
  }
  diferencialEmpleadosCajasTottus = system 'Diferencial de Empleados para Cajas Tottus' {
    #people
    description 'aplicación que recolecta archivo de empleados de los negocios de falabella Perú y realiza un cruce de datos con el archivo de empleados del dia anterior, el resultado se arma en archivos .dat compatibles para cajas y es enviado por FTP a todas las cajas de las tiendas de Tottus.'
    diferencialEmpleadosCajasTottus -[supportsCapability]-> employeeMaster "Supports"
  }
  intranetMiCasa = system 'Intranet Mi Casa' {
    #people
    description 'Reemplaza Intranet Corporativa Sodimac'
    intranetMiCasa -[supportsCapability]-> employeeMaster "Supports"
  }
  ocupacionalSSO = system 'Ocupacional- SSO' {
    #people
    description 'Sistema de Gestión de Salud y Seguridad Ocupacional (SSO)'
    ocupacionalSSO -[supportsCapability]-> employeeMaster "Supports"
    ocupacionalSSO -[supportsCapability]-> benefits "Supports"
  }
  ofisisSmart = system 'Ofisis Smart' {
    #people
    description 'Plataforma de personal, remuneraciones y asistencia'
    ofisisSmart -[supportsCapability]-> employeeMaster "Supports"
    ofisisSmart -[supportsCapability]-> timeAndAttendance "Supports"
    ofisisSmart -[supportsCapability]-> payrollCapability "Supports"
  }
  spr = system 'Personal y Remuneraciones - SPR' {
    #people, #APP00314,#Critical
    description 'Sistema de Personal y Remuneraciones.Evaluación Puestos Claves.Triple Pack (contratos/Renovación/Finiquito).Evaluación de desempeño. FMC Formulario de modificación Contractual . Adm y gestión del Personal. Remuneraciones. AutoConsulta.Vendedores a POS / descuento Institucional. Workflow de Vacaciones.'
    spr -[supportsCapability]-> employeeMaster "Supports"
  }
  planillaEjecutivos = system 'Planilla Ejecutivos (Fox Pro)'{
    #people
    description 'Sistema de planilla de ejecutivos para Saga Falabella - Perú. Solo contempla nóminas. En tecnología Fox Pro con DBFs.. (pasa a pre-apagado)'
    planillaEjecutivos -[supportsCapability]-> employeeMaster "Supports"
  }
  sprSaas = system 'Personal y Remuneraciones - SPR Saas' {
    #people
    description 'Sistema de Personal y Remuneraciones.Evaluación Puestos Claves.Triple Pack (contratos/Renovación/Finiquito).Evaluación de desempeño. FMC Formulario de modificación Contractual . Adm y gestión del Personal. Remuneraciones. AutoConsulta.Vendedores a POS / descuento Institucional. Workflow de Vacaciones.. Sistema tipo SaaS.'
    sprSaas -[supportsCapability]-> employeeMaster "Supports"
  }
  nomina = system 'SAP_corp / SAP Nómina' {
    #people
    description 'Modulo SAP para gestión de recursos humanos. (En nuestra planificación seguirá vivo hasta 2028 al menos)'
    nomina -[supportsCapability]-> employeeMaster "Supports"
  }
  sprWeb = system 'SPR-WEB' {
    #people
    description 'Desarrollos Java para aplicaciones de RRHH en el portal Falanet, especialmente conectado a la base de SPR, con lo que se han creado modulos de autoatención y workflow, desde solicitud de vacaiones, firma de documentos laborales, workflow de prestamos, informes de comisiones, formularios de modificación contractual, beneficios flexibles,'
    sprWeb -[supportsCapability]-> employeeMaster "Supports"
  }
  empleadoCentral = system 'SAP SF Employee Central' {
    #people, #APP00281
    description 'Sistema de administración de personal (en la nube)Sistema de reclutamiento y selección, tanto interno como externoMódulo de perfil de la plataforma del grupo Falabella de SSFF'
    
    empleadoCentral -[supportsCapability]-> organizationalDesign "Supports"

    empleadoCentral -[usesApplication]-> geoVictoria 
    empleadoCentral -[usesApplication]-> spr
    empleadoCentral -[usesApplication]-> employeeCentralPayroll
    empleadoCentral -[usesApplication]-> aira
  }
  adobeSign = system 'Adobe Sign'{
    #people
    description 'Solución de Firma Digital'
    metadata {
      FAI 'APP02046'
      LifeCycle 'Mantener/Evolucionar'
    }
    adobeSign -[supportsCapability]-> documents "Supports"
