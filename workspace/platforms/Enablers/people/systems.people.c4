//systems.people.c4
model {
  qualtrics = system 'Qualtrics'{
    #people
    description 'Employee survey application'
    metadata {
      FAI 'APP02590'
    }
    qualtrics -[supportsCapability]-> voiceOfEmployee "Supports"
  }

  relojbiometricoSpr = system {
    #people #Sodimac-Chile #Sodimac-Uruguay #APP00306
    title 'Reloj biométrico SPR'
    description 'Sistema para control de asistencia'
    metadata {
      Lifecycle 'Retirar'
      Codebase 'Build'
      Delivery 'On-Site'
    }
    relojbiometricoSpr -[supportsCapability]-> timeAndAttendance "Supports"
  }

  saba = system 'Saba'{
    #people
    description '	Sistema de E-learning. Capacitaciones del Area de Gestión Humana para funcionarios del Banco'
    metadata {
      FAI 'APP00764'
    }
    saba -[supportsCapability]-> learning "Supports"
  }

  firmaElectronicaPersonalInterno = system 'Firma Electrónica Personal Interno'{
    #people
    description 'Sistema que incorpora la huella digital a los documentos legales y laborales de cada trabajador. El proceso de enrolamiento de huella se realiza en Falanet y queda asociada al Rut.'
    metadata {
      FAI 'APP01645'
    }
    firmaElectronicaPersonalInterno -[supportsCapability]-> electronicSign "Supports"
  }

  sapNomina = system 'SAP Nómina'{
    #people
    description 'SAP Payroll Module'
    metadata {
      FAI 'APP00166'
    }
    sapNomina -[supportsCapability]-> payrollCapability "Supports"
  }

  falanetApp = system 'Falanet (App)'{
    #people
    description 'App Interna para los empleados del grupo, en donde se pueden crear grupos y segmentar las publicaciones de noticias, comunicados, beneficios, conectar aplicaciones externas (responsive) ,buscar empleados, conectar chatbot, hacer la evaluacion de desempeño. Actualmente Falabella Retail Chile y Adessa pueden solicitar entradas de cine, utilizar las gift card electronicas de vestuario.'
    metadata {
      FAI 'APP00284'
    }
    falanetApp -[supportsCapability]-> caseManagementPeople "Supports"
  }

  relojesMarcadoresPe = system 'Relojes Marcadores PE'{
    #people
    description '	Permite registrar las marcas de los empleados.'
    metadata {
      FAI 'APP00307'
    }
    relojesMarcadoresPe -[supportsCapability]-> timeAndAttendance "Supports"
  }

  miFalabella = system 'Mi Falabella'{
    #people
    description 'ERM Application'
    metadata {
      FAI 'APP02588'
    }
    miFalabella -[supportsCapability]-> erm "Supports"
  }

  firmaElectronicabyFalabella = system 'Firma Electronica by Falabella'{
    #people
    description 'Firma electrónica para documentos'
    metadata {
      FAI 'APP03053'
    }
    firmaElectronicabyFalabella -[supportsCapability]-> electronicSign "Supports"
  }

  portalBeneficios = system 'Portal Beneficios'{
    #people
    description 'Beneficios transversales para los colaboradores, reporte de métricas.'
    metadata {
      FAI 'APP02779'
    }
    portalBeneficios -[supportsCapability]-> benefits "Supports"
  }

  payflow = system 'Payflow'{
    #people
