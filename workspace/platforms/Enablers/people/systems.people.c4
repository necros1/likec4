    #people
    description 'Solución de Firma Digital'
    metadata {
      FAI 'APP02045'
    }
    eSign -[supportsCapability]-> electronicSign "Supports"
  }
  
  portalEmpleados = system 'Portal Empleados'{
    #people
    description 'Solución rrhh para gestión de empleados'
    metadata {
      FAI 'APP02043'
    }
    portalEmpleados -[supportsCapability]-> caseManagementPeople "Supports"
  }

  degree = system 'Degree'{
    #people
    description '	Solución LMS (Learning Management System) para Learning'
    metadata {
      FAI 'APP01968'
    }
    degree -[supportsCapability]-> learning "Supports"
  }
  
  wimper = system 'Wimper'{
    #people
    description 'Gestión del proceso y herramientas para ejecución de pagos de remuneraciones e incentivos. Es un servicio BPO'
    metadata {
      FAI 'APP01967'
    }
    wimper -[supportsCapability]-> learning "Supports"
    wimper -[supportsCapability]-> payrollCapability "Supports"
  }

  ubits = system 'Ubits'{
    #people
    description 'Plataforma de contenidos para capacitación empresarial'
    metadata {
      FAI 'APP01712'
    }
    ubits -[supportsCapability]-> learning "Supports"
  }

  muevete = system 'Muevete'{
    #people
    description 'Plataforma de convocatorias Internas para vacantes del Grupo Falabella.'
    metadata {
      FAI 'APP01217'
    }
    muevete -[supportsCapability]-> attraction "Supports"
  }

  trabajandoCom = system 'Trabajando.com'{
    #people
    description 'Plataforma de Evaluación de Desempeño'
    metadata {
      FAI 'APP00999'
    }
    trabajandoCom -[supportsCapability]-> onBoarding "Supports"
  }

  rankmi = system 'Rankmi'{
    #people
    description 'Plataforma de Evaluación de Desempeño'
    metadata {
      FAI 'APP00955'
    }
    rankmi -[supportsCapability]-> performance "Supports"
  }

  payroll = system 'payroll'{
    #people
    description 'Plataforma de gestión de empleados y pago de nóminas y gestión de tiempos de Adecco'
    metadata {
      FAI 'APP00934'
      LifeCycle 'Deprecar'
    }
    payroll -[supportsCapability]-> payrollCapability "Supports"
  }

  getAbstract = system 'Get Abstract'{
    #people
    description 'Plataforma de conocimiento'
    metadata {
      FAI 'APP00909'
    }
    getAbstract -[supportsCapability]-> learning "Supports"
  }

  eClass = system 'e-Class'{
    #people
    description 'Sistema de e-Learning'
    metadata {
      FAI 'APP00904'
    }
    eClass -[supportsCapability]-> learning "Supports"
  }

  sysnel = system 'Sysnel'{
    #people
