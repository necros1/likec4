  aira = system 'Aira' { 
    #people
    description ''' 
      Sistema de RRHH para el reclutamiento y selección de personal interno y externo a Falabella 
      ###
      [Page](https://falabella.airavirtual.com/recruiter/login)
      [Confluence 1](https://confluence.falabella.com/pages/viewpage.action?pageId=142585500)
      [Confluence 2](https://confluence.falabella.com/pages/viewpage.action?pageId=133226844)
    '''
    metadata {
      FAI 'APP02021'
      LifeCycle 'Implementar'
    }
    aira -[supportsCapability]-> attraction "Supports"
  }

