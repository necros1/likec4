    metadata {
      FAI 'APP00863'
      LifeCycle 'Deprecar'
    }
    sysnel -[supportsCapability]-> timeAndAttendance "Supports"
  }
  
  nomiplus = system 'Nomiplus'{
    #people
    description 'Sistema de administraciòn de Nomina'
    metadata {
      FAI 'APP00698'
      LifeCycle 'Mantener/Evolucionar'
    }
    nomiplus -[supportsCapability]-> payrollCapability "Supports"
  }

