  gestorDocumentosCorporativoHyland = system 'Gestor De Documentos Corporativo-Hyland' {
    #people
    description 'Document repository for contracts, attendance tickets'
    gestorDocumentosCorporativoHyland -[supportsCapability]-> documents "Supports"
  }

  catalyst = system 'Catalyst' {
    #APP00848,#purchase
    -> accountingGateway 'uses'
  }
  saperp = system 'SAP ERP'{
    #APP00201,#finance, #Critical
